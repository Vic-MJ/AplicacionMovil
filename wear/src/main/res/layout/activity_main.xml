<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    >

    <ScrollView
        android:id="@+id/scrollChat"
        android:layout_width="171dp"
        android:layout_height="87dp"
        app:layout_constraintBottom_toTopOf="@id/cajaTexto"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0">

        <TextView
            android:id="@+id/etiquetaResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chat con el celular"
            android:textSize="12sp" />

    </ScrollView>

    <EditText
        android:id="@+id/cajaTexto"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Mensaje"
        android:inputType="text"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@id/botonEnviar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/botonEnviar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enviar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
